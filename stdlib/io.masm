@section data
@section text

print:
PUSHR fp
MOV fp, sp
PUSH16 65534
PUSHR fp
ADD
POPR sp
PUSH16 0
STR [fp, 0]

L0:
LDR [fp, 6]
LDR [fp, 0]
PUSH16 1
MUL
ADD
LDB
PUSH16 0
CMP
JEQ L2
JMP L1
JMP L2

L1:
